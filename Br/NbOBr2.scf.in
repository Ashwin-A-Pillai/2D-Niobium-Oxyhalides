&control
    calculation = 'scf'
    prefix = 'NbOBr2'
    pseudo_dir = '/home/pillai/my_codes/yambo/NbOX2/PS'
    outdir = './outs'
    verbosity = 'high'
    wf_collect = .true.
    tprnfor = .true.
    tstress = .true.
/

&system
    ibrav = 8
    A = 7.071127061
    B = 3.928511538
    C = 25.000000000

    nat = 8
    ntyp = 3

    ecutwfc = 80
    nbnd = 110

    input_dft = 'PBE'

    occupations = 'smearing'
    smearing = 'mv'
    degauss = 0.005

    assume_isolated = '2D'
/

&electrons
    mixing_mode = 'local-TF'
    mixing_beta = 0.08
    mixing_ndim = 12
    conv_thr = 1.0d-10
    electron_maxstep = 300
    diagonalization = 'david'
    diago_david_ndim = 4
/

