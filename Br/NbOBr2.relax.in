&control
    calculation = 'relax'
    prefix = 'NbOBr2'
    pseudo_dir = '/home/pillai/my_codes/yambo/NbOX2/PS'
    outdir = './outs'
    verbosity = 'high'
    wf_collect = .true.
    tprnfor = .true.
    tstress = .false.
    etot_conv_thr = 1.0d-6
    forc_conv_thr = 1.0d-4
    nstep = 100
    restart_mode = 'from_scratch'
/

&system
    ibrav = 8
    A = 7.071127061
    B = 3.928511538
    C = 25.000000

    nat = 8
    ntyp = 3

    ecutwfc = 80
    input_dft = 'PBE'

    occupations = 'smearing'
    smearing = 'mv'
    degauss = 0.005

    assume_isolated = '2D'
/

&electrons
    mixing_mode = 'local-TF'
    mixing_beta = 0.08
    mixing_ndim = 12
    conv_thr = 1.0d-10
    electron_maxstep = 300
    diagonalization = 'david'
    diago_david_ndim = 4
/

&ions
    ion_dynamics = 'bfgs'
/

ATOMIC_SPECIES
    Nb  92.90638   Nb_ONCV_PBE-1.2.upf
    O   15.99940   O_ONCV_PBE-1.2.upf
    Br  79.90400   Br_ONCV_PBE-1.2.upf

