&control
    calculation = 'scf'
    prefix = 'NbOCl2'
    pseudo_dir = '/home/pillai/my_codes/yambo/NbOX2/PS'
    outdir = './outs'
    verbosity = 'high'
    wf_collect = .true.
    tprnfor = .true.
    tstress = .true.
/

&system
    ibrav = 8
    A = 6.7529891415
    B = 3.9277613333
    C = 25.0000000000

    nat = 8
    ntyp = 3

    ecutwfc = 80
    nbnd = 80

    input_dft = 'PBE'

    occupations = 'fixed'

    assume_isolated = '2D'
/

&electrons
    mixing_mode = 'local-TF'
    mixing_beta = 0.05
    mixing_ndim = 12
    conv_thr = 1.0d-10
    electron_maxstep = 300
    diagonalization = 'david'
    diago_david_ndim = 2
/

